# ── Database ──────────────────────────────────────────────────
# From Render PostgreSQL dashboard → "External Connection String"
DATABASE_URL="postgresql://user:password@host:5432/adore"

# ── Auth ──────────────────────────────────────────────────────
# Any long random string (min 32 chars)
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"

# ── Cloudinary ────────────────────────────────────────────────
# From https://cloudinary.com/console → "API Environment variable"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ── Razorpay ──────────────────────────────────────────────────
# From https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY="rzp_test_xxxxxxxxxxxx"
RAZORPAY_SECRET="your_razorpay_secret"

# ── Cashfree ──────────────────────────────────────────────────
# From https://merchant.cashfree.com/merchants/developers
CASHFREE_APP_ID="your_cashfree_app_id"
CASHFREE_SECRET="your_cashfree_secret"

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Google Analytics (optional) ───────────────────────────────
# Add your GA4 Measurement ID in the Admin → Analytics panel (stored in localStorage)
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# ── Firebase Cloud Messaging (optional, for push notifications) ──
# From https://console.firebase.google.com/project/YOUR_PROJECT/settings/serviceaccounts
# FCM_SERVER_KEY="your_fcm_server_key"
